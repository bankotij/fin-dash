# Optional: base URL for the mock JSON API (see vite-plugin-mock-server in repo).
# Dev default is http://localhost:3000 when unset.
# For a static Vercel deploy only, leave unset — Overview renders; chart/card widgets need an API.
# If you host the mock server on a free tier (e.g. Render), set:
# VITE_API_BASE_URL=https://your-mock-api.onrender.com

VITE_API_BASE_URL=
